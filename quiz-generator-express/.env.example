# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram (/newbot)
TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Secret token sent with every webhook request (set the same value when running /setup)
# Generate a random string: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# ─── GitHub Question Bank ─────────────────────────────────────────────────────
# Personal Access Token — needs Contents: Read & Write on the repo
# GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Also accepted: GITHUB_PERSONAL_ACCESS_TOKEN=...
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repository in owner/name format
GITHUB_REPO=yourname/quiz-questions

# Branch to commit to (default: main)
GITHUB_BRANCH=main

# ─── Turso Database (analytics) ───────────────────────────────────────────────
# Create a free database at turso.tech
TURSO_DB_URL=https://your-db-name-yourorg.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ─── OpenRouter AI ────────────────────────────────────────────────────────────
# Free API key from openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Security ─────────────────────────────────────────────────────────────────
# Protects /setup and /initdb endpoints
# Pass as: GET /setup?secret=YOUR_SECRET  or  X-Admin-Secret: YOUR_SECRET header
ADMIN_SECRET=your_admin_secret_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Used as HTTP-Referer in OpenRouter calls (optional, defaults to quiz-generator.workers.dev)
WORKER_ORIGIN=https://your-domain.vercel.app
